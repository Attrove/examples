# User secret key (starts with sk_). Get this from provisioning a user via the admin API.
# This is NOT your partner client_id/client_secret.
ATTROVE_SECRET_KEY=sk_your_secret_key_here
ATTROVE_USER_ID=your-user-uuid-here

# Optional: override for local or staging testing.
# ATTROVE_BASE_URL=https://api.attrove.com
